{
  "name": "udbx4ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript UDBX runtime for Web and Electron.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./web": {
      "types": "./dist/runtime-browser/index.d.ts",
      "import": "./dist/runtime-browser/index.js",
      "require": "./dist/runtime-browser/index.cjs"
    },
    "./electron": {
      "types": "./dist/runtime-electron/index.d.ts",
      "import": "./dist/runtime-electron/index.js",
      "require": "./dist/runtime-electron/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf coverage dist .tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:browser": "playwright test",
    "test:watch": "vitest",
    "dev:browser": "vite --config examples/browser/vite.config.ts examples/browser --host 127.0.0.1 --port 5173",
    "dev:electron": "echo \"Electron example wiring will be added in the electron runtime phase.\""
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.0.0",
    "chai": "5.2.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "^3.51.2-build8"
  },
  "peerDependencies": {
    "better-sqlite3": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    }
  }
}
